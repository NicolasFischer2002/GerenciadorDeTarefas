<Window x:Class="GerenciadorDeTarefas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GerenciadorDeTarefas"
        mc:Ignorable="d"
        Title="Gerenciador de Tarefas"
        Icon="/Assets/Icone-Tarefa.ico"
        Height="710"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F6FB">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0 0 0 30">

            <TextBlock Text="Gerenciador de Tarefas"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       VerticalAlignment="Center"/>

            <TextBlock Text="🗂"
                       FontSize="26"
                       Margin="10 0 0 0"
                       Foreground="{StaticResource PrimaryBrush}"
                       VerticalAlignment="Center"/>

        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource BackgroundBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0 0 0 20"
                BorderBrush="#D9E2F2"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="Título"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0 0 0 6"/>

                <TextBox x:Name="TituloTextBox"
                         Text="{Binding Titulo, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0 0 0 15"/>

                <TextBlock Text="Descrição"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0 0 0 6"/>

                <TextBox x:Name="DescricaoTextBox"
                         Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0 0 0 20"/>

                <Button Content="Adicionar"
                        Click="AdicionarButton_Click"
                        Cursor="Hand"
                        Style="{StaticResource PrimaryButtonStyle}"/>

            </StackPanel>

        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource BackgroundBrush}"
                CornerRadius="10"
                Padding="15"
                BorderBrush="#D9E2F2"
                BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0 5 0 0">

                <StackPanel>
                    <TextBlock Text="Lista de tarefas"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"
                               Margin="0 20"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 15">

                        <TextBlock Text="Filtrar:"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0 0 10 0"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="StatusFiltroComboBox"
                                  Width="180"
                                  Style="{StaticResource DefaultComboBoxStyle}"
                                  SelectionChanged="StatusFiltroComboBox_SelectionChanged">

                            <ComboBoxItem Content="Todos"
                                          IsSelected="True"/>

                            <ComboBoxItem Content="Pendente"/>

                            <ComboBoxItem Content="EmProgresso"/>

                            <ComboBoxItem Content="Concluida"/>

                        </ComboBox>

                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Tarefas}">

                        <ItemsControl.ItemTemplate>

                            <DataTemplate>

                                <Border Background="#F8FAFC"
                                        CornerRadius="6"
                                        Padding="12"
                                        Margin="0 0 0 10"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">

                                    <Grid>

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>

                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontSize="15"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold">

                                            <Run Text="{Binding Titulo}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding Status}"/>

                                        </TextBlock>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal">

                                            <Button Content="✏"
                                                    Margin="0 0 8 0"
                                                    ToolTip="Editar"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Cursor="Hand"
                                                    Click="EditarButton_Click"/>

                                            <Button Click="ExcluirButton_Click"
                                                    Content="🗑"
                                                    ToolTip="Excluir"
                                                    Cursor="Hand"
                                                    Style="{StaticResource DangerIconButtonStyle}"/>

                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</Window>