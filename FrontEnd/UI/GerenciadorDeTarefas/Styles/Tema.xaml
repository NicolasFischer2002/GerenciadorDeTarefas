<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ========================= -->
    <!-- Cores -->
    <!-- ========================= -->
    <Color x:Key="PrimaryColor">#0040B4</Color>
    <Color x:Key="DangerColor">#D32F2F</Color>
    <Color x:Key="BackgroundColor">#F3F6FB</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    
    <!-- ========================= -->
    <!-- Botão base -->
    <!-- ========================= -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <!-- ========================= -->
    <!-- Botão principal -->
    <!-- ========================= -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ========================= -->
    <!-- Botão ícone -->
    <!-- ========================= -->
    
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ========================= -->
    <!-- Ícone botão excluir -->
    <!-- ========================= -->
    
    <Style x:Key="DangerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    </Style>
    
    <!-- ========================= -->
    <!-- Texto do botão cancelar -->
    <!-- ========================= -->
    
    <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <!-- ========================= -->
    <!-- Input -->
    <!-- ========================= -->
    
    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="10 6"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="BorderBrush" Value="#C5D2E8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
    </Style>

    <!-- ========================= -->
    <!-- Combobox -->
    <!-- ========================= -->
    
    <Style x:Key="DefaultComboBoxStyle"
       TargetType="ComboBox">

        <Setter Property="Height"
            Value="38"/>

        <Setter Property="FontSize"
            Value="15"/>

        <Setter Property="Padding"
            Value="10 6"/>

        <Setter Property="Background"
            Value="White"/>

        <Setter Property="BorderBrush"
            Value="#C5D2E8"/>

        <Setter Property="BorderThickness"
            Value="1"/>

        <Setter Property="Foreground"
            Value="#334155"/>

        <Setter Property="FontFamily"
            Value="Segoe UI"/>

    </Style>
</ResourceDictionary>