<Window x:Class="GerenciadorDeTarefas.EditarTarefaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Tarefa"
        Icon="/Assets/Icone-Tarefa.ico"
        Height="440"
        Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Detalhes da Tarefa"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1">

            <TextBlock Text="Título"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#334155"
                       Margin="0 0 0 6"/>

            <TextBox x:Name="TituloTextBox"
                     Style="{StaticResource InputTextBoxStyle}" />

            <TextBlock Text="Descrição"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#334155"
                       Margin="0 0 0 6"/>

            <TextBox x:Name="DescricaoTextBox"
                     Style="{StaticResource InputTextBoxStyle}"
                     Height="120"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

        </StackPanel>

        <Button x:Name="StatusActionButton"
                Grid.Row="2"
                Content="Ação"
                Margin="0,10,0,10"
                Style="{StaticResource PrimaryButtonStyle}"
                Cursor="Hand"
                Click="StatusActionButton_Click"/>

        <Grid Grid.Row="3"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Cancelar"
                    Width="110"
                    Style="{StaticResource CancelButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click"/>

            <Button Content="Salvar"
                    Width="110"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Salvar_Click"/>

        </StackPanel>

    </Grid>
</Window>